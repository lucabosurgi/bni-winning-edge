# ── Supabase ──────────────────────────────────────────────
# Project Settings → API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# service_role key — server-only, NEVER exposed to the browser.
# Used by the concierge to write leads and (later) by admin tooling.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI concierge ──────────────────────────────────────────
# https://console.anthropic.com  → API Keys
ANTHROPIC_API_KEY=sk-ant-...
# Optional override; sensible default is set in code.
CONCIERGE_MODEL=claude-3-5-haiku-latest

# ── Site ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://bniwinningedge.com

# ── Admin (leads page at /admin) ──────────────────────────
# Pick any strong password; you'll enter it to view captured leads.
ADMIN_PASSWORD=choose-a-strong-password
